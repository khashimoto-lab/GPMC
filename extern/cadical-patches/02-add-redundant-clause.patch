+void Solver::add_redundant_clause (const std::vector<int> &lits, int glue) {
+  REQUIRE (lits.size () >= 2,
+           "redundant clause must have at least two literals");
+  // The flag is scoped to this single clause: set before the literals and
+  // cleared after the terminating 'add (0)' that finalizes the clause. This
+  // keeps the API stateless from the caller's point of view.
+  internal->adding_redundant = true;
+  internal->adding_redundant_glue = glue;
+  for (auto lit : lits) {
+    REQUIRE_VALID_LIT (lit);
+    add (lit);
+  }
+  add (0);
+  internal->adding_redundant = false;
+  internal->adding_redundant_glue = 0;
+}
+
 bool Solver::inconsistent () { return internal->unsat; }
 
