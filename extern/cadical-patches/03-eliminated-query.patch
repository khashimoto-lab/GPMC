+// Implemented here for keeping it all inline (requires Internal::flags).
+// Mirrors 'External::fixed' but reports the ELIMINATED status of the
+// variable instead of an implied root-level assignment.  The sign of 'elit'
+// is irrelevant, so unlike 'fixed' we do not flip 'ilit'.
+
+inline int External::eliminated (int elit) const {
+  assert (elit);
+  assert (elit != INT_MIN);
+  int eidx = abs (elit);
+  if (eidx > max_var)
+    return 0;
+  int ilit = e2i[eidx];
+  if (!ilit)
+    return 0;
+  return internal->flags (ilit).eliminated ();
+}
