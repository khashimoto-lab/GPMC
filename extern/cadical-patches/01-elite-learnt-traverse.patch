+// Same as 'traverse_clauses' above, but also exports redundant (learnt)
+// clauses whose glue is at most 'glue_limit'. The clause's 'redundant' flag is
+// passed to the iterator so the caller can tell originals from learnt clauses.
+//
+bool Internal::traverse_clauses_with_elite_learnts (ClauseIterator &it,
+                                                    int glue_limit) {
+  vector<int> eclause;
+  if (unsat)
+    return it.clause (eclause, false);
+  for (const auto &c : clauses) {
+    if (c->garbage)
+      continue;
+    if (c->redundant && c->glue > glue_limit)
+      continue;
+    bool satisfied = false;
+    for (const auto &ilit : *c) {
+      const int tmp = fixed (ilit);
+      if (tmp > 0) {
+        satisfied = true;
+        break;
+      }
+      if (tmp < 0)
+        continue;
+      const int elit = externalize (ilit);
+      eclause.push_back (elit);
+    }
+    if (!satisfied && !it.clause (eclause, c->redundant))
+      return false;
+    eclause.clear ();
+  }
+  return true;
+}
